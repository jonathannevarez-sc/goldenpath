# Copy to mcp/.env for local MCP development (optional).
# Values mirror config/enterprise.env — see config/enterprise.env.example.

GOLDENPATH_ROOT=
GOLDENPATH_CONFIG=
GOLDENPATH_CHANNEL=stable
GOLDENPATH_VERSION=

# Defaults from enterprise.env when unset: GCP_SANDBOX_PROJECT, then GCP_DEV_PROJECT
GCP_PROJECT=
GCP_REGION=

MCP_TRANSPORT=stdio
MCP_HOST=0.0.0.0
MCP_PORT=8080
MCP_API_KEY=
MCP_SERVICE_NAME=

GITHUB_TOKEN=
GH_TOKEN=
SHOP_CLI=