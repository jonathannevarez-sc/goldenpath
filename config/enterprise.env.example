# Golden Path enterprise configuration
# Copy to config/enterprise.env and customize for your organization.
# All scripts, CLI, and wizard read from this file (or GOLDENPATH_CONFIG override).
#
#   cp config/enterprise.env.example config/enterprise.env
#   $EDITOR config/enterprise.env

# ── Billing anchor ─────────────────────────────────────────────────────────────
# Existing GCP project used only for billing linkage. Golden Path never deploys here.
PARENT_PROJECT_ID=your-billing-anchor-project
BILLING_ACCOUNT_ID=XXXXXX-XXXXXX-XXXXXX

# ── GCP projects ─────────────────────────────────────────────────────────────
GCP_DEV_PROJECT=your-org-goldenpath-dev
GCP_PROD_PROJECT=your-org-goldenpath-prod

# Isolated sandbox for personal/CI testing (optional — used by standup-teardown-env.sh)
GCP_SANDBOX_PROJECT=your-org-goldenpath-sandbox
SANDBOX_PROJECT_NAME="Golden Path Sandbox"
SANDBOX_PROJECT_LABELS=purpose=goldenpath,lifecycle=sandbox

# ── Region ───────────────────────────────────────────────────────────────────
GCP_REGION=us-central1

# ── GitHub ─────────────────────────────────────────────────────────────────────
GITHUB_ORG=your-github-org
PLATFORM_REPO=goldenpath

# Version tag for reusable deploy workflows (must exist on this repo)
GOLDENPATH_VERSION=v0.3.8

# ── Platform resource names (shared conventions) ───────────────────────────────
ARTIFACT_REGISTRY_REPO=shop-services
MCP_SERVICE_NAME=goldenpath-mcp

# ── Safety ─────────────────────────────────────────────────────────────────────
# Projects teardown scripts must NEVER delete (comma-separated)
PROTECTED_PROJECTS=your-billing-anchor-project,your-org-goldenpath-prod

# Projects allowed for teardown (comma-separated; empty = any non-protected sandbox)
ALLOWED_TEARDOWN_PROJECTS=