# Golden Path — platform team canonical config (TEMPLATE)
#
# PLATFORM TEAM ONLY — fill real values, save as enterprise.env.team (gitignored).
# Do not commit enterprise.env.team or enterprise.env.
#
# ── Platform record (update when values change) ─────────────────────────────
# Organization:     your-org-name
# Maintained by:      platform-team@your-org.com
# Last updated:       YYYY-MM-DD
# Shared via:         1Password / internal vault / ticket attachment
# Bootstrap status:   not started | dev bootstrapped | dev+prod bootstrapped
# Notes:              optional runbook links
#
# ── Developer onboarding (send engineers this one-liner) ──────────────────────
#   cp config/enterprise.env.team config/enterprise.env
#   gcloud auth login && gcloud auth application-default login && gh auth login
#
# ── How to create the team file ─────────────────────────────────────────────
#   cp config/enterprise.env.team.example config/enterprise.env.team
#   $EDITOR config/enterprise.env.team
#   cp config/enterprise.env.team config/enterprise.env   # local platform verify
#
# FinOps / GCP admin fills billing fields. Product engineers do not need billing access.

# ── Billing anchor ─────────────────────────────────────────────────────────────
# Existing GCP project used only for billing linkage. Golden Path never deploys here.
PARENT_PROJECT_ID=your-billing-anchor-project
BILLING_ACCOUNT_ID=XXXXXX-XXXXXX-XXXXXX

# ── GCP projects ─────────────────────────────────────────────────────────────
GCP_DEV_PROJECT=your-org-goldenpath-dev
GCP_PROD_PROJECT=your-org-goldenpath-prod

# Shared sandbox for personal/CI testing (standup-teardown-env.sh)
GCP_SANDBOX_PROJECT=your-org-goldenpath-sandbox
SANDBOX_PROJECT_NAME="Golden Path Sandbox"
SANDBOX_PROJECT_LABELS=purpose=goldenpath,lifecycle=sandbox

# ── Region ───────────────────────────────────────────────────────────────────
GCP_REGION=us-central1

# ── GitHub ─────────────────────────────────────────────────────────────────────
GITHUB_ORG=your-github-org
PLATFORM_REPO=goldenpath

# Version tag for reusable deploy workflows (must exist on this repo)
GOLDENPATH_VERSION=v0.3.7

# ── Platform resource names ────────────────────────────────────────────────────
ARTIFACT_REGISTRY_REPO=shop-services
MCP_SERVICE_NAME=goldenpath-mcp

# ── Safety ─────────────────────────────────────────────────────────────────────
# Projects teardown scripts must NEVER delete (comma-separated)
PROTECTED_PROJECTS=your-billing-anchor-project,your-org-goldenpath-prod

# Projects allowed for teardown (comma-separated; empty = any non-protected sandbox)
ALLOWED_TEARDOWN_PROJECTS=